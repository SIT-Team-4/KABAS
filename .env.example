PORT=3001

DB_HOST=127.0.0.1
DB_PORT=3307
DB_ROOT_PASSWORD=your_db_root_password
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# Set to true for managed MySQL (e.g., DigitalOcean) that requires SSL
DB_SSL=false

# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your_64_char_hex_string

# JWT Authentication
# Generate with: openssl rand -hex 32
JWT_SECRET=your_jwt_secret
JWT_EXPIRY=24h

# API key fallback for server-to-server or admin integrations
ADMIN_API_KEY=your_admin_api_key

# Comma-separated CORS allowlist for frontend origins
# Example: http://localhost:3000,https://kabas-client.onrender.com
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Frontend: backend API base URL (used by React app via REACT_APP_ prefix)
# Must be set in CI/CD and production deployments (e.g., Render)
# Defaults to http://localhost:3001/api if unset
REACT_APP_API_BASE_URL=http://localhost:3001/api
